---
import type { CollectionEntry } from "astro:content";

interface Props {
  item: CollectionEntry<"gallery">;
}

const { item } = Astro.props;
---

<article class="surface-card rounded-[1.75rem] p-5 transition duration-300 hover:-translate-y-1 hover:border-brand-500/40">
  <div class="aspect-[4/3] rounded-[1.25rem] border border-white/10 bg-[linear-gradient(135deg,rgba(63,125,117,0.16),rgba(24,24,27,0.02))] dark:bg-[linear-gradient(135deg,rgba(94,234,212,0.16),rgba(15,23,42,0.4))]"></div>
  <h2 class="mt-4 text-lg font-semibold text-[color:var(--text)]">{item.data.title}</h2>
  <p class="body-muted mt-2 text-sm">{item.data.alt}</p>
</article>
