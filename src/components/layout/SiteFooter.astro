---
import Container from "@/components/ui/Container.astro";
import { getNavigation, getPhoneHref, getSiteSettings, getSocialLinks, getWhatsappHref } from "@/lib/content/site";

const site = getSiteSettings();
const navigation = getNavigation();
const socialLinks = getSocialLinks();
const phoneHref = getPhoneHref();
const whatsappHref = getWhatsappHref();
---

<footer class="border-t border-white/10 bg-stone-950 text-slate-300">
  <Container class="space-y-10 py-10 text-sm text-stone-600">
    <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div class="space-y-4">
        <div class="space-y-2">
          <p class="text-lg font-semibold text-white">{site.siteName}</p>
          <p class="max-w-sm leading-6 text-slate-400">{site.slogan}</p>
        </div>
        <div class="space-y-2">
          <p class="text-slate-400">{site.contact.address}</p>
          <a href={phoneHref} class="block text-slate-200 hover:text-brand-300">{site.contact.phone}</a>
          <a href={whatsappHref} class="block text-emerald-300 hover:text-emerald-200">WhatsApp ile ulas</a>
          <a href={`mailto:${site.contact.email}`} class="block text-slate-200 hover:text-brand-300">{site.contact.email}</a>
        </div>
      </div>

      {navigation.footerGroups.map((group) => (
        <div class="space-y-3">
          <p class="font-semibold text-white">{group.title}</p>
          <ul class="space-y-2">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="text-slate-400 hover:text-brand-300">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="flex flex-col gap-4 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <ul class="flex flex-wrap gap-4">
        {socialLinks.links.map((item) => (
          <li>
            <a href={item.url} class="text-slate-400 hover:text-brand-300">{item.label}</a>
          </li>
        ))}
      </ul>
      <ul class="flex flex-wrap gap-4">
        {navigation.footerBottom.map((item) => (
          <li>
            <a href={item.href} class="text-slate-400 hover:text-brand-300">{item.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </Container>
</footer>
