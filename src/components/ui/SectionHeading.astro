---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="max-w-3xl space-y-3">
  {eyebrow && <p class="eyebrow-label">{eyebrow}</p>}
  <h2 class="text-3xl font-bold tracking-tight text-[color:var(--text)] sm:text-4xl">{title}</h2>
  {text && <p class="body-muted text-base leading-7">{text}</p>}
</div>
