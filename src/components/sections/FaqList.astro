---
import type { CollectionEntry } from "astro:content";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";

interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  items: CollectionEntry<"faq">[];
  ctaLabel?: string;
  ctaHref?: string;
}

const { eyebrow, title, text, items, ctaLabel, ctaHref } = Astro.props;
---

<section class="py-16 sm:py-20">
  <Container class="space-y-10">
    <SectionHeading eyebrow={eyebrow} title={title} text={text} />
    <div class="space-y-4">
      {items.map((item) => (
        <article class="surface-card rounded-[1.5rem] p-6">
          <h3 class="text-lg font-semibold text-[color:var(--text)]">{item.data.question}</h3>
          <p class="body-muted mt-3 text-sm leading-6">{item.data.answer}</p>
        </article>
      ))}
    </div>
    {ctaLabel && ctaHref && (
      <a href={ctaHref} class="inline-flex items-center gap-2 text-sm font-semibold text-brand-700 transition hover:text-brand-500 dark:text-brand-200 dark:hover:text-white">
        {ctaLabel}
        <span aria-hidden="true">→</span>
      </a>
    )}
  </Container>
</section>
