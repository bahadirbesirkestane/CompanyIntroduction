---
import Container from "@/components/ui/Container.astro";

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
}

const { eyebrow, title, text, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="py-16 sm:py-20">
  <Container>
    <div class="rounded-[2rem] border border-brand-500/20 bg-[linear-gradient(180deg,rgba(63,125,117,0.12),rgba(255,255,255,0.82))] px-6 py-10 shadow-[0_18px_50px_rgba(15,23,42,0.08)] dark:bg-[linear-gradient(180deg,rgba(63,125,117,0.18),rgba(24,24,27,0.92))] sm:px-10">
      <div class="max-w-3xl space-y-4">
        {eyebrow && <p class="eyebrow-label">{eyebrow}</p>}
        <h2 class="text-3xl font-bold tracking-tight text-[color:var(--text)] sm:text-4xl">{title}</h2>
        <p class="text-base leading-7 text-[color:var(--muted)]">{text}</p>
        <div class="flex flex-wrap gap-4">
          <a href={primaryHref} class="btn-whatsapp">
            {primaryLabel}
          </a>
          <a href={secondaryHref} class="btn-secondary">
            {secondaryLabel}
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
