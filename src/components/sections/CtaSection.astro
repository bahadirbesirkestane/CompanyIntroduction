---
import Container from "@/components/ui/Container.astro";

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  buttonLabel: string;
  buttonHref: string;
}

const { eyebrow, title, text, buttonLabel, buttonHref } = Astro.props;
---

<section class="py-16 sm:py-20">
  <Container>
    <div class="overflow-hidden rounded-[2rem] border border-brand-500/20 bg-[linear-gradient(135deg,#285853_0%,#1f3f45_55%,#111827_100%)] px-6 py-10 text-white shadow-[0_24px_80px_rgba(15,23,42,0.24)] sm:px-10">
      <div class="max-w-3xl space-y-4">
        {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-100">{eyebrow}</p>}
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
        <p class="text-base leading-7 text-brand-50/90">{text}</p>
        <a href={buttonHref} class="btn-whatsapp">
          {buttonLabel}
        </a>
      </div>
    </div>
  </Container>
</section>
